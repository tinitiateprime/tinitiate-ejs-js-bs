<%
  const raw = rawData || {};
  const cssVars = theme && theme.cssVars ? theme.cssVars : {};

  function escapeHtml(value) {
    return String(value === undefined || value === null ? "" : value)
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;")
      .replace(/'/g, "&#39;");
  }

  function safeCss(value) {
    return String(value || "").replace(/[;{}]/g, "");
  }

  function pageHref(item) {
    return item.path === "/" ? "/preview" : item.path;
  }

  function buildNavTree(items) {
    const ids = new Set(items.map((item) => item.id));
    const normalizedItems = items.map((item) => ({
      ...item,
      navPath: item.path && item.path !== "/" ? String(item.path).replace(/\/+$/g, "") : "/"
    }));
    const byId = new Map(normalizedItems.map((item) => [item.id, item]));
    const byParent = new Map();

    function inferParentId(item) {
      if (item.parentId && ids.has(item.parentId) && item.parentId !== item.id) {
        return item.parentId;
      }

      if (!item.navPath || item.navPath === "/") {
        return null;
      }

      const parent = normalizedItems
        .filter((candidate) => {
          if (candidate.id === item.id || candidate.navPath === "/") return false;
          return item.navPath.startsWith(`${candidate.navPath}/`);
        })
        .sort((left, right) => right.navPath.length - left.navPath.length)[0];

      return parent ? parent.id : null;
    }

    normalizedItems.forEach((item) => {
      const parentId = inferParentId(item);
      const parentKey = parentId && byId.has(parentId) ? parentId : "__root__";
      byParent.set(parentKey, [...(byParent.get(parentKey) || []), item]);
    });

    function createNode(item, seen = new Set()) {
      if (seen.has(item.id)) {
        return { page: item, children: [] };
      }

      const nextSeen = new Set(seen);
      nextSeen.add(item.id);

      return {
        page: item,
        children: (byParent.get(item.id) || []).map((child) => createNode(child, nextSeen))
      };
    }

    return (byParent.get("__root__") || []).map((item) => createNode(item));
  }

  function navNodeIsActive(node) {
    return node.page.id === page.id || node.children.some((child) => navNodeIsActive(child));
  }

  function flattenNavChildren(nodes, depth = 0) {
    return nodes.flatMap((node) => [
      { page: node.page, depth },
      ...flattenNavChildren(node.children, depth + 1)
    ]);
  }

  const navTree = buildNavTree(pages);

  function getContent(section) {
    if (section.content !== undefined) return section.content;
    return raw[section.type] || {};
  }

  function asArray(value) {
    if (Array.isArray(value)) return value;
    if (value && Array.isArray(value.items)) return value.items;
    if (value && Array.isArray(value.list)) return value.list;
    if (value && Array.isArray(value.cards)) return value.cards;
    if (value && Array.isArray(value.features)) return value.features;
    if (value && Array.isArray(value.services)) return value.services;
    return [];
  }

  function pick(value, keys, fallback) {
    if (!value || typeof value !== "object") return fallback;
    for (const key of keys) {
      if (value[key] !== undefined && value[key] !== null && String(value[key]).trim() !== "") {
        return value[key];
      }
    }
    return fallback;
  }

  function imageUrl(value) {
    const image = pick(value, ["image", "imageUrl", "photo", "thumbnail", "background"], "");
    if (!image) return "";
    if (typeof image === "string") return image;
    return image.url || image.src || "";
  }

  function buttonList(content) {
    const buttons = content.buttons || content.ctas || content.actions || [];
    if (!Array.isArray(buttons)) return "";

    return buttons
      .map((button) => {
        const label = button.label || button.title || button.text || "Learn more";
        const href = button.href || button.url || "#";
        const style = button.variant === "secondary" ? "outline-primary" : "primary";
        return `<a class="btn btn-${style}" href="${escapeHtml(href)}">${escapeHtml(label)}</a>`;
      })
      .join("");
  }

  function renderCards(items) {
    if (!items.length) return "";

    return `
      <div class="row g-4">
        ${items
          .map((item) => {
            const value = typeof item === "object" ? item : { title: item };
            const title = pick(value, ["title", "name", "label", "heading"], "Item");
            const text = pick(value, ["description", "text", "summary", "content"], "");
            const icon = pick(value, ["icon"], "");
            return `
              <div class="col-md-6 col-lg-4">
                <article class="content-card h-100">
                  ${icon ? `<div class="content-icon">${escapeHtml(icon)}</div>` : ""}
                  <h3 class="h5">${escapeHtml(title)}</h3>
                  ${text ? `<p>${escapeHtml(text)}</p>` : ""}
                </article>
              </div>
            `;
          })
          .join("")}
      </div>
    `;
  }

  function renderKeyValues(content) {
    if (!content || typeof content !== "object" || Array.isArray(content)) return "";

    const ignored = new Set(["title", "heading", "subtitle", "description", "text", "buttons", "ctas", "actions", "items", "cards", "features", "services", "image", "imageUrl", "photo", "background"]);
    const rows = Object.entries(content).filter(([key, value]) => !ignored.has(key) && typeof value !== "object");

    if (!rows.length) return "";

    return `
      <dl class="row key-values">
        ${rows
          .map(([key, value]) => `
            <dt class="col-sm-4">${escapeHtml(key.replace(/[-_]/g, " "))}</dt>
            <dd class="col-sm-8">${escapeHtml(value)}</dd>
          `)
          .join("")}
      </dl>
    `;
  }

  function normalizeFooterLinks(links) {
    if (!Array.isArray(links)) return [];

    return links
      .map((group) => {
        if (typeof group === "string") {
          return {
            group: "",
            items: [{ label: group, path: "#" }]
          };
        }

        if (Array.isArray(group.items)) {
          return {
            group: group.group || group.title || group.label || "",
            items: group.items
          };
        }

        return {
          group: "",
          items: [group]
        };
      })
      .filter((group) => group.items.length);
  }

  function renderFooterLink(item) {
    if (typeof item === "string") {
      return `<a href="#">${escapeHtml(item)}</a>`;
    }

    const label = item.label || item.title || item.name || item.text || "Link";
    const href = item.path || item.href || item.url || "#";
    return `<a href="${escapeHtml(href)}">${escapeHtml(label)}</a>`;
  }

  function renderFooterGroups(links) {
    const groups = normalizeFooterLinks(links);

    if (!groups.length) return "";

    return `
      <nav class="footer-links" aria-label="Footer">
        ${groups
          .map(
            (group) => `
              <div class="footer-link-group">
                ${group.group ? `<h2>${escapeHtml(group.group)}</h2>` : ""}
                <div class="footer-link-list">
                  ${group.items.map((item) => renderFooterLink(item)).join("")}
                </div>
              </div>
            `
          )
          .join("")}
      </nav>
    `;
  }

  function renderHero(section) {
    const content = getContent(section);
    const title = pick(content, ["title", "heading", "name"], site.title);
    const subtitle = pick(content, ["subtitle", "tagline", "description", "text"], site.description);
    const image = imageUrl(content);

    return `
      <section class="site-section hero-section">
        <div class="container">
          <div class="hero-grid ${image ? "" : "hero-grid-single"}">
            <div>
              <p class="section-kicker">${escapeHtml(section.title)}</p>
              <h1>${escapeHtml(title)}</h1>
              ${subtitle ? `<p class="hero-copy">${escapeHtml(subtitle)}</p>` : ""}
              <div class="button-row">${buttonList(content)}</div>
            </div>
            ${image ? `<img class="hero-image" src="${escapeHtml(image)}" alt="${escapeHtml(title)}">` : ""}
          </div>
        </div>
      </section>
    `;
  }

  function renderAbout(section) {
    const content = getContent(section);
    const title = pick(content, ["title", "heading", "name"], section.title);
    const text = pick(content, ["description", "text", "summary", "content"], "");
    const items = asArray(content);

    return `
      <section class="site-section">
        <div class="container">
          <div class="section-heading">
            <p class="section-kicker">${escapeHtml(section.title)}</p>
            <h2>${escapeHtml(title)}</h2>
            ${text ? `<p>${escapeHtml(text)}</p>` : ""}
          </div>
          ${renderCards(items)}
          ${renderKeyValues(content)}
        </div>
      </section>
    `;
  }

  function renderComparison(section) {
    const content = getContent(section);
    const rows = content.rows || asArray(content);
    const columns = content.columns || (rows[0] && typeof rows[0] === "object" ? Object.keys(rows[0]) : []);

    if (!rows.length || !columns.length) {
      return renderGeneric(section);
    }

    return `
      <section class="site-section">
        <div class="container">
          <div class="section-heading">
            <p class="section-kicker">${escapeHtml(section.title)}</p>
            <h2>${escapeHtml(pick(content, ["title", "heading"], section.title))}</h2>
          </div>
          <div class="table-responsive">
            <table class="table align-middle comparison-table">
              <thead>
                <tr>${columns.map((column) => `<th>${escapeHtml(column)}</th>`).join("")}</tr>
              </thead>
              <tbody>
                ${rows
                  .map((row) => `
                    <tr>
                      ${columns.map((column) => `<td>${escapeHtml(row[column] || "")}</td>`).join("")}
                    </tr>
                  `)
                  .join("")}
              </tbody>
            </table>
          </div>
        </div>
      </section>
    `;
  }

  function renderGeneric(section) {
    const content = getContent(section);
    const items = asArray(content);
    const title = pick(content, ["title", "heading", "name"], section.title);
    const text = typeof content === "string" ? content : pick(content, ["description", "text", "summary", "content"], "");

    return `
      <section class="site-section">
        <div class="container">
          <div class="section-heading">
            <p class="section-kicker">${escapeHtml(section.title)}</p>
            <h2>${escapeHtml(title)}</h2>
            ${text ? `<p>${escapeHtml(text)}</p>` : ""}
          </div>
          ${renderCards(items)}
          ${renderKeyValues(content)}
        </div>
      </section>
    `;
  }

  function renderSection(section) {
    if (section.type === "header" || section.type === "hero") return renderHero(section);
    if (section.type === "about") return renderAbout(section);
    if (section.type === "comparison") return renderComparison(section);
    return renderGeneric(section);
  }

  function renderFooter() {
    const footer = raw.footer || {};

    if (typeof footer === "string") {
      return `
        <div class="site-footer-grid">
          <div class="footer-brand-block">
            <div class="footer-brand">${escapeHtml(site.brand)}</div>
            <p>${escapeHtml(footer)}</p>
          </div>
        </div>
      `;
    }

    const brand = footer.brand || site.brand;
    const tagline = footer.tagline || footer.text || footer.description || site.description;
    const copyright = footer.copyright || footer.copy || "";

    return `
      <div class="site-footer-grid">
        <div class="footer-brand-block">
          <div class="footer-brand">${escapeHtml(brand)}</div>
          ${tagline ? `<p>${escapeHtml(tagline)}</p>` : ""}
          ${copyright ? `<p class="footer-copy">${escapeHtml(copyright)}</p>` : ""}
        </div>
        ${renderFooterGroups(footer.links || footer.navigation || footer.menu)}
      </div>
    `;
  }
%>
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= page.title %> | <%= site.title %></title>
    <link rel="preconnect" href="https://cdn.jsdelivr.net">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
      :root {
        <% Object.entries(cssVars).forEach(([key, value]) => { %>
          <%= key %>: <%= safeCss(value) %>;
        <% }) %>
      }

      body {
        margin: 0;
        color: var(--site-text);
        background: var(--site-bg);
        font-family: var(--site-body-font);
      }

      h1,
      h2,
      h3,
      h4,
      h5,
      h6 {
        color: var(--site-text);
        font-family: var(--site-heading-font);
        letter-spacing: 0;
      }

      .site-navbar {
        border-bottom: 1px solid var(--site-border);
        background: rgba(255, 255, 255, 0.94);
        backdrop-filter: blur(12px);
      }

      .navbar-brand {
        color: var(--site-text);
        font-weight: 800;
      }

      .nav-link {
        color: var(--site-muted);
        font-weight: 600;
      }

      .nav-link.active,
      .nav-link:hover {
        color: var(--site-primary);
      }

      .nav-link.dropdown-toggle {
        border: 0;
        background: transparent;
      }

      .dropdown-menu {
        border-color: var(--site-border);
        border-radius: var(--site-radius);
        box-shadow: 0 18px 38px rgba(15, 23, 42, 0.12);
      }

      .dropdown-item {
        color: var(--site-muted);
        font-weight: 600;
      }

      .dropdown-item:hover,
      .dropdown-item.active {
        color: var(--site-primary);
        background: rgba(37, 99, 235, 0.08);
      }

      .dropdown-item.active {
        font-weight: 800;
      }

      .site-section {
        padding: 4rem 0;
      }

      .site-section:nth-child(even) {
        background: var(--site-surface);
      }

      .hero-section {
        padding: 5rem 0;
        background:
          linear-gradient(135deg, rgba(37, 99, 235, 0.1), rgba(15, 118, 110, 0.1)),
          var(--site-bg);
      }

      .hero-grid {
        display: grid;
        grid-template-columns: minmax(0, 1.05fr) minmax(280px, 0.95fr);
        align-items: center;
        gap: 2.5rem;
      }

      .hero-grid-single {
        grid-template-columns: minmax(0, 780px);
      }

      .hero-section h1 {
        max-width: 760px;
        margin: 0;
        font-size: clamp(2.35rem, 6vw, 4.8rem);
        line-height: 1;
        font-weight: 850;
      }

      .hero-copy {
        max-width: 680px;
        margin: 1.2rem 0 0;
        color: var(--site-muted);
        font-size: 1.15rem;
      }

      .hero-image {
        width: 100%;
        aspect-ratio: 4 / 3;
        object-fit: cover;
        border-radius: var(--site-radius);
        border: 1px solid var(--site-border);
      }

      .button-row {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
        margin-top: 1.5rem;
      }

      .btn-primary {
        --bs-btn-bg: var(--site-primary);
        --bs-btn-border-color: var(--site-primary);
        --bs-btn-hover-bg: var(--site-secondary);
        --bs-btn-hover-border-color: var(--site-secondary);
      }

      .btn-outline-primary {
        --bs-btn-color: var(--site-primary);
        --bs-btn-border-color: var(--site-primary);
        --bs-btn-hover-bg: var(--site-primary);
        --bs-btn-hover-border-color: var(--site-primary);
      }

      .section-heading {
        max-width: 760px;
        margin-bottom: 2rem;
      }

      .section-heading h2 {
        margin: 0;
        font-size: clamp(1.8rem, 4vw, 3rem);
        font-weight: 800;
      }

      .section-heading p:not(.section-kicker) {
        margin: 0.75rem 0 0;
        color: var(--site-muted);
        font-size: 1.05rem;
      }

      .section-kicker {
        margin-bottom: 0.65rem;
        color: var(--site-primary);
        font-size: 0.78rem;
        font-weight: 800;
        letter-spacing: 0;
        text-transform: uppercase;
      }

      .content-card {
        padding: 1.25rem;
        border: 1px solid var(--site-border);
        border-radius: var(--site-radius);
        background: #fff;
      }

      .content-card p {
        margin-bottom: 0;
        color: var(--site-muted);
      }

      .content-icon {
        width: 40px;
        height: 40px;
        display: grid;
        place-items: center;
        margin-bottom: 1rem;
        border-radius: var(--site-radius);
        color: #fff;
        background: var(--site-secondary);
        font-weight: 800;
      }

      .key-values {
        max-width: 760px;
        padding: 1rem;
        border: 1px solid var(--site-border);
        border-radius: var(--site-radius);
        background: #fff;
      }

      .key-values dt {
        color: var(--site-text);
        text-transform: capitalize;
      }

      .key-values dd {
        color: var(--site-muted);
      }

      .comparison-table {
        overflow: hidden;
        border: 1px solid var(--site-border);
        border-radius: var(--site-radius);
      }

      .comparison-table thead th {
        color: var(--site-text);
        background: var(--site-surface);
      }

      .site-footer {
        padding: 3rem 0 2rem;
        border-top: 1px solid var(--site-border);
        color: var(--site-muted);
        background: #fff;
      }

      .site-footer-grid {
        display: grid;
        grid-template-columns: minmax(220px, 1.2fr) minmax(0, 2fr);
        gap: 2rem;
        align-items: start;
      }

      .footer-brand {
        margin-bottom: 0.65rem;
        color: var(--site-text);
        font-size: 1.15rem;
        font-weight: 850;
      }

      .footer-brand-block p {
        max-width: 420px;
        margin: 0;
      }

      .footer-brand-block p + p {
        margin-top: 0.75rem;
      }

      .footer-copy {
        font-size: 0.9rem;
      }

      .footer-links {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 1.5rem;
      }

      .footer-link-group h2 {
        margin: 0 0 0.65rem;
        color: var(--site-text);
        font-size: 0.85rem;
        font-weight: 800;
      }

      .footer-link-list {
        display: grid;
        gap: 0.45rem;
      }

      .footer-link-list a {
        color: var(--site-muted);
        text-decoration: none;
      }

      .footer-link-list a:hover {
        color: var(--site-primary);
      }

      .template-modern-saas .hero-section {
        background:
          linear-gradient(135deg, rgba(37, 99, 235, 0.16), rgba(245, 158, 11, 0.12)),
          var(--site-bg);
      }

      .template-modern-saas .content-card {
        box-shadow: 0 18px 40px rgba(15, 23, 42, 0.08);
      }

      .template-editorial .hero-grid,
      .template-editorial .hero-grid-single {
        grid-template-columns: minmax(0, 860px);
      }

      .template-editorial .hero-section h1 {
        font-family: Georgia, "Times New Roman", serif;
      }

      @media (max-width: 767.98px) {
        .site-section,
        .hero-section {
          padding: 3rem 0;
        }

        .hero-grid {
          grid-template-columns: 1fr;
          gap: 1.5rem;
        }

        .site-footer-grid,
        .footer-links {
          grid-template-columns: 1fr;
        }
      }
    </style>
  </head>
  <body class="template-<%= template.id %>">
    <nav class="navbar navbar-expand-lg site-navbar sticky-top">
      <div class="container">
        <a class="navbar-brand" href="/preview"><%= site.brand %></a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#previewNav" aria-controls="previewNav" aria-expanded="false" aria-label="Toggle navigation">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="previewNav">
          <ul class="navbar-nav ms-auto">
            <% navTree.forEach((node) => { %>
              <% if (node.children.length) { %>
                <li class="nav-item dropdown">
                  <button
                    class="nav-link dropdown-toggle <%= navNodeIsActive(node) ? 'active' : '' %>"
                    type="button"
                    data-bs-toggle="dropdown"
                    aria-expanded="false"
                  >
                    <%= node.page.title %>
                  </button>
                  <ul class="dropdown-menu dropdown-menu-end">
                    <li>
                      <a class="dropdown-item <%= node.page.id === page.id ? 'active' : '' %>" href="<%= pageHref(node.page) %>">
                        <%= node.page.title %>
                      </a>
                    </li>
                    <li><hr class="dropdown-divider"></li>
                    <% flattenNavChildren(node.children).forEach((item) => { %>
                      <li>
                        <a
                          class="dropdown-item <%= item.page.id === page.id ? 'active' : '' %>"
                          style="padding-left: <%= 1 + item.depth * 0.85 %>rem"
                          href="<%= pageHref(item.page) %>"
                        >
                          <%= item.page.title %>
                        </a>
                      </li>
                    <% }) %>
                  </ul>
                </li>
              <% } else { %>
                <li class="nav-item">
                  <a class="nav-link <%= node.page.id === page.id ? 'active' : '' %>" href="<%= pageHref(node.page) %>"><%= node.page.title %></a>
                </li>
              <% } %>
            <% }) %>
          </ul>
        </div>
      </div>
    </nav>

    <main>
      <% sections.forEach((section) => { %>
        <%- renderSection(section) %>
      <% }) %>
    </main>

    <footer class="site-footer">
      <div class="container">
        <%- renderFooter() %>
      </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
