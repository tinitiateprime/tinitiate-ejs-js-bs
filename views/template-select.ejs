<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Select Template | <%= site.title %></title>
    <link rel="preconnect" href="https://cdn.jsdelivr.net">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <style>
      :root {
        color-scheme: light;
        --builder-bg: #f5f7fb;
        --builder-panel: #ffffff;
        --builder-border: #dce5f0;
        --builder-text: #142033;
        --builder-muted: #67758a;
        --builder-primary: #2563eb;
        --builder-secondary: #0f766e;
      }

      * {
        box-sizing: border-box;
      }

      body {
        min-height: 100vh;
        margin: 0;
        font-family: Inter, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        color: var(--builder-text);
        background:
          linear-gradient(180deg, rgba(37, 99, 235, 0.08), rgba(15, 118, 110, 0) 360px),
          var(--builder-bg);
      }

      .template-shell {
        min-height: 100vh;
        display: grid;
        grid-template-rows: auto 1fr auto;
      }

      .topbar {
        border-bottom: 1px solid var(--builder-border);
        background: rgba(255, 255, 255, 0.88);
        backdrop-filter: blur(14px);
      }

      .brand-mark {
        width: 38px;
        height: 38px;
        display: grid;
        place-items: center;
        border-radius: 8px;
        color: #fff;
        background: linear-gradient(135deg, var(--builder-primary), var(--builder-secondary));
      }

      .template-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 1rem;
      }

      .template-card {
        position: relative;
        min-height: 300px;
        display: flex;
        flex-direction: column;
        border: 1px solid var(--builder-border);
        border-radius: 8px;
        padding: 1rem;
        background: var(--builder-panel);
        cursor: pointer;
        transition: transform 160ms ease, border-color 160ms ease, box-shadow 160ms ease;
      }

      .template-card:hover,
      .template-card:focus-visible {
        transform: translateY(-2px);
        border-color: rgba(37, 99, 235, 0.45);
        box-shadow: 0 16px 40px rgba(20, 32, 51, 0.12);
        outline: 0;
      }

      .template-card.is-selected {
        border-color: var(--builder-primary);
        box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.16);
      }

      .template-card .check {
        position: absolute;
        top: 0.9rem;
        right: 0.9rem;
        width: 28px;
        height: 28px;
        display: grid;
        place-items: center;
        border-radius: 50%;
        color: #fff;
        background: var(--builder-primary);
        opacity: 0;
      }

      .template-card.is-selected .check {
        opacity: 1;
      }

      .preview-frame {
        flex: 1;
        min-height: 150px;
        border: 1px solid #e5edf6;
        border-radius: 8px;
        overflow: hidden;
        background: #fff;
      }

      .preview-top {
        height: 30px;
        border-bottom: 1px solid #e5edf6;
        background: #f8fafc;
      }

      .preview-body {
        padding: 14px;
      }

      .preview-line {
        height: 9px;
        border-radius: 999px;
        background: #d8e3ef;
      }

      .preview-line.short {
        width: 42%;
      }

      .preview-line.medium {
        width: 64%;
      }

      .preview-block {
        height: 52px;
        border-radius: 8px;
        background: linear-gradient(135deg, rgba(37, 99, 235, 0.14), rgba(15, 118, 110, 0.14));
      }

      .template-icon {
        width: 42px;
        height: 42px;
        display: grid;
        place-items: center;
        border-radius: 8px;
        color: #fff;
        background: var(--builder-primary);
      }

      .footerbar {
        border-top: 1px solid var(--builder-border);
        background: rgba(255, 255, 255, 0.92);
      }

      .continue-btn {
        min-width: 150px;
      }

      @media (max-width: 991.98px) {
        .template-grid {
          grid-template-columns: 1fr;
        }
      }
    </style>
  </head>
  <body>
    <div class="template-shell">
      <header class="topbar">
        <div class="container py-3 d-flex align-items-center justify-content-between gap-3">
          <div class="d-flex align-items-center gap-3">
            <div class="brand-mark"><i class="bi bi-bootstrap"></i></div>
            <div>
              <div class="fw-semibold"><%= site.title %></div>
              <div class="small text-secondary">GitHub powered mini website builder</div>
            </div>
          </div>
          <a class="btn btn-sm btn-outline-secondary" href="<%= site.source.repository %>" target="_blank" rel="noreferrer">
            <i class="bi bi-github me-1"></i> Data Source
          </a>
        </div>
      </header>

      <main class="container py-4 py-lg-5">
        <div class="row align-items-end mb-4">
          <div class="col-lg-8">
            <p class="text-uppercase small fw-semibold text-primary mb-2">Template</p>
            <h1 class="h2 mb-2">Choose a Bootstrap starting point</h1>
            <p class="text-secondary mb-0"><%= site.description %></p>
          </div>
        </div>

        <div class="template-grid" id="templateGrid">
          <% templates.forEach((template) => { %>
            <button
              class="template-card text-start <%= template.id === selectedTemplate ? 'is-selected' : '' %>"
              type="button"
              data-template-id="<%= template.id %>"
              aria-pressed="<%= template.id === selectedTemplate ? 'true' : 'false' %>"
            >
              <span class="check"><i class="bi bi-check-lg"></i></span>
              <div class="d-flex align-items-center gap-3 mb-3">
                <span class="template-icon bg-<%= template.accent %>">
                  <i class="bi <%= template.icon %>"></i>
                </span>
                <div>
                  <h2 class="h5 mb-1"><%= template.name %></h2>
                  <p class="small text-secondary mb-0"><%= template.description %></p>
                </div>
              </div>
              <div class="preview-frame mt-auto" aria-hidden="true">
                <div class="preview-top"></div>
                <div class="preview-body">
                  <div class="preview-line short mb-2"></div>
                  <div class="preview-line medium mb-3"></div>
                  <div class="preview-block mb-3"></div>
                  <div class="row g-2">
                    <div class="col"><div class="preview-line"></div></div>
                    <div class="col"><div class="preview-line"></div></div>
                    <div class="col"><div class="preview-line"></div></div>
                  </div>
                </div>
              </div>
            </button>
          <% }) %>
        </div>
      </main>

      <footer class="footerbar">
        <div class="container py-3 d-flex align-items-center justify-content-between gap-3">
          <div class="small text-secondary">
            Loaded from <span class="fw-semibold"><%= site.source.repository %></span>
          </div>
          <button class="btn btn-primary continue-btn" type="button" id="continueBtn">
            Continue <i class="bi bi-arrow-right ms-1"></i>
          </button>
        </div>
      </footer>
    </div>

    <script>
      const cards = Array.from(document.querySelectorAll("[data-template-id]"));
      const continueBtn = document.getElementById("continueBtn");
      let selectedTemplate = "<%= selectedTemplate %>";

      function selectTemplate(id) {
        selectedTemplate = id;
        cards.forEach((card) => {
          const isSelected = card.dataset.templateId === id;
          card.classList.toggle("is-selected", isSelected);
          card.setAttribute("aria-pressed", String(isSelected));
        });
      }

      cards.forEach((card) => {
        card.addEventListener("click", () => selectTemplate(card.dataset.templateId));
      });

      continueBtn.addEventListener("click", async () => {
        continueBtn.disabled = true;
        continueBtn.innerHTML = "Loading...";

        const response = await fetch("/select-template", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ template: selectedTemplate })
        });

        if (!response.ok) {
          continueBtn.disabled = false;
          continueBtn.innerHTML = "Continue <i class=\"bi bi-arrow-right ms-1\"></i>";
          return;
        }

        const result = await response.json();
        window.location.href = result.redirect || "/";
      });
    </script>
  </body>
</html>
